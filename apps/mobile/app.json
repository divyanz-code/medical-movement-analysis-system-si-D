{
  "expo": {
    "name": "MEDMOVE AI",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medmove",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Camera enables real-time AI movement and facial analysis.",
        "NSMicrophoneUsageDescription": "Microphone records voice notes during rehab sessions.",
        "NSPhotoLibraryUsageDescription": "Save your session recordings for review."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F766E"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F766E"
        }
      ],
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "MEDMOVE AI uses your camera for real-time movement and facial analysis.",
          "microphonePermission": "MEDMOVE AI uses your microphone to record audio during video sessions."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
